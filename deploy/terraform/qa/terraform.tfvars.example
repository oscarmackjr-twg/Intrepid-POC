# Copy to terraform.tfvars and set values (do not commit terraform.tfvars with real secrets)
# For CI/CD: export TF_VAR_db_password='<password>'

aws_region   = "us-east-1"
app_name     = "intrepid-poc"
environment  = "qa"

# S3: intrepid-poc-qa
s3_bucket_name = "intrepid-poc-qa"

# RDS: intrepid-poc-qa
db_instance_identifier = "intrepid-poc-qa"
db_password            = "CHANGE_ME"   # Set via env: export TF_VAR_db_password='...'

# ECS (compute): intrepid-poc-qa
ecs_cluster_name    = "intrepid-poc-qa"
ecs_service_name    = "intrepid-poc-qa"
ecr_repository_name = "intrepid-poc-qa"
