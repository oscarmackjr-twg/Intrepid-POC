# backend/.env.example — committed template
# Copy this file to backend/.env and fill in your values.
# See DEVELOPMENT.md for full setup instructions.

## LOCAL DEV
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intrepid_poc
STORAGE_TYPE=local
# SECRET_KEY: generate a strong random key for local dev. Any string works locally.
SECRET_KEY=local-dev-secret-key-change-in-production
LOCAL_DEV_MODE=false  # Set to true for local dev only

# DEV_INPUT: path to your files_required directory (the pipeline's input folder).
# Points at the committed sample dataset by default — run with --pdate 2026-02-19.
# Override with your own real files_required directory to use live data.
DEV_INPUT=./data/sample/files_required
# DEV_OUTPUT=      # Optional: override local output directory
# DEV_OUTPUT_SHARED=  # Optional: override shared output directory

## S3 / PRODUCTION
# Uncomment and fill these in when deploying to staging/production.
# STORAGE_TYPE=s3
# S3_BUCKET_NAME=      # Your S3 bucket name
# S3_REGION=us-east-1  # AWS region
# S3_INPUT=input/files_required   # S3 prefix for input files
# S3_OUTPUT=outputs               # S3 prefix for output files
# S3_OUTPUT_SHARED=output_share   # S3 prefix for shared output files
# AWS_PROFILE=         # AWS CLI profile (local only — not used in ECS)
# AWS_ACCESS_KEY_ID=   # Set via Secrets Manager in production
# AWS_SECRET_ACCESS_KEY=
